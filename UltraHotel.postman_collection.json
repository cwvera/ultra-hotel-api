{
  "info": {
    "_postman_id": "a3f1c2e4-7b8d-4e9a-b0c5-2d6f8a1e3c7b",
    "name": "UltraHotel API – Prueba E2E",
    "description": "Flujo completo contra datos del seed de SQL Server.\n\nUsuarios seed:\n  admin@ultrahotel.com    / Ultra1234!  (ADMIN)    — crea agentes\n  agent@ultrahotel.com    / Ultra1234!  (AGENT)    — gestiona hoteles/habitaciones\n  traveler@ultrahotel.com / Ultra1234!  (TRAVELER) — hace reservas\n\nReglas de creación de usuarios:\n  POST /auth/register  → siempre crea TRAVELER (público, sin token)\n  POST /auth/agents    → crea AGENT (requiere token ADMIN)\n  ADMIN solo existe en seed, no se crea por API\n\nHoteles seed:\n  A1A1A1A1-... → Hotel Casa Bogotá\n  A2A2A2A2-... → Hotel El Poblado Medellín\n\nHabitaciones seed:\n  B1B1B1B1-...0001 → SINGLE  Bogotá\n  B1B1B1B1-...0002 → DOUBLE  Bogotá\n  B1B1B1B1-...0003 → SUITE   Bogotá\n  B2B2B2B2-...0001 → FAMILY  Medellín\n  B2B2B2B2-...0002 → DOUBLE  Medellín\n\nBase URL: http://localhost:8080 (Docker Compose)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080",                        "type": "string" },
    { "key": "adminToken",    "value": "",                                              "type": "string" },
    { "key": "agentToken",    "value": "",                                              "type": "string" },
    { "key": "travelerToken", "value": "",                                              "type": "string" },
    { "key": "hotelId1",      "value": "A1A1A1A1-0000-0000-0000-000000000001",         "type": "string" },
    { "key": "hotelId2",      "value": "A2A2A2A2-0000-0000-0000-000000000002",         "type": "string" },
    { "key": "roomId1",       "value": "B1B1B1B1-0000-0000-0000-000000000001",         "type": "string" },
    { "key": "roomId2",       "value": "B1B1B1B1-0000-0000-0000-000000000002",         "type": "string" },
    { "key": "roomId3",       "value": "B2B2B2B2-0000-0000-0000-000000000001",         "type": "string" },
    { "key": "bookingId",     "value": "",                                              "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth – Obtener tokens",
      "item": [
        {
          "name": "1.1 Login Admin → guarda adminToken",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Tiene token', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
            "pm.test('Rol es ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));",
            "pm.collectionVariables.set('adminToken', json.token);",
            "console.log('adminToken guardado. userId:', json.userId);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"admin@ultrahotel.com\",\n  \"password\": \"Ultra1234!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
